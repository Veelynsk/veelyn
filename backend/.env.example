# Skopíruj do .env a vyplň reálnymi hodnotami.

# Port servera (default 3001)
PORT=3001

# Heslo do admin API (zmeň!)
ADMIN_PASSWORD=zmen-toto-heslo-123

# Email pre notifikácie o nových objednávkach
SELLER_EMAIL=info@veelyn.sk

# Odosielateľ (musí byť overený v Resend dashboarde po pridaní domény veelyn.sk)
FROM_EMAIL=Veelyn <objednavky@veelyn.sk>

# Resend API kľúč — zaregistruj sa na https://resend.com (100 emailov/deň zadarmo)
# Bez tohto kľúča server stále funguje, ale emaily sa LEN logujú do backend/logs/V1234.json
RESEND_API_KEY=

# ── SUPERFAKTURA ───────────────────────────────────────────────
# Email tvojho účtu na https://moja.superfaktura.sk
SF_EMAIL=
# API kľúč: Nastavenia → Nástroje → API → vytvor nový token
SF_APIKEY=
# Voliteľné: ID firmy ak v jednom účte máš viac firiem
SF_COMPANY_ID=
# 20 ak si platiteľ DPH, 0 ak nie. Default 0.
SF_VAT_RATE=0
# transfer | cash | card | other  — defaultný spôsob úhrady na faktúre
SF_PAYMENT_TYPE=transfer

# Bez SF_EMAIL + SF_APIKEY je integrácia vypnutá a objednávky fungujú
# ako doteraz (do SQLite + email). Po vyplnení sa pri každej novej
# objednávke automaticky vytvorí faktúra v SuperFaktura, a keď v admin
# UI prepneš objednávku na "paid", označí sa zaplatená aj v SF.

# ── MAILERLITE ─────────────────────────────────────────────────
# API v2 token z MailerLite dashboardu (Integrations → API → Generate).
# Bez tohto je integrácia no-op a objednávky/newsletter fungujú aj
# bez napojenia. Po vyplnení sa:
#   - newsletter form vo footeri pridá email do skupiny "Newsletter"
#   - úspešná objednávka pridá zákazníka do skupiny "Customers"
#   - vyplnenie checkout step 1 (bez completion) pridá do "Abandoned cart"
# Automatizované emaily (welcome, abandoned cart win-back, post-purchase
# review) sa konfigurujú v MailerLite UI → Automations.
MAILERLITE_TOKEN=

# ── PACKETA ────────────────────────────────────────────────────
# REST API password z client.packeta.com → Zákaznícka podpora →
# Heslo API (tajný kľúč, NIKDY nie v gite). Widget API key (verejný)
# je hardcoded vo frontende — to nie sú tie isté hodnoty.
# Backend ho používa pre:
#   - POST /api/admin/orders/:id/shipment   → vytvorí zásielku v Packete
#   - GET  /api/admin/orders/:id/shipment/label → stiahne PDF štítok
PACKETA_API_PASSWORD=
